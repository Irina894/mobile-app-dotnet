<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WhatToCook.MAUI.Views.CalendarPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WhatToCook.MAUI.ViewModels"
    xmlns:model="clr-namespace:WhatToCook.MAUI.Models"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ContentPage.BindingContext>
        <vm:CalendarViewModel/>
    </ContentPage.BindingContext>
    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ═══ HEADER ═══ -->
                <VerticalStackLayout
                    BackgroundColor="{StaticResource Primary}"
                    Padding="20,52,20,18"
                    Spacing="16">

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Cooking Plan"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                            <Border WidthRequest="30" HeightRequest="30" StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PrevWeekCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="‹" TextColor="White" FontSize="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="{Binding CurrentMonthYear}" TextColor="White"
                                   FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Border WidthRequest="30" HeightRequest="30" StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NextWeekCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="›" TextColor="White" FontSize="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Week strip -->
                    <CollectionView ItemsSource="{Binding WeekDays}" HeightRequest="66"
                                    HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:WeekDay">
                                <VerticalStackLayout Spacing="5" WidthRequest="44"
                                                     HorizontalOptions="Center" Padding="0,2">
                                    <VerticalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=SelectDayCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </VerticalStackLayout.GestureRecognizers>

                                    <Label Text="{Binding DayName}" FontSize="10"
                                           HorizontalOptions="Center" TextColor="#AADAFF"/>

                                    <Border WidthRequest="34" HeightRequest="34"
                                            StrokeThickness="0" HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="17"/>
                                        </Border.StrokeShape>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="False">
                                                <Setter Property="BackgroundColor" Value="Transparent"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding DayNumber}" FontSize="14"
                                               FontAttributes="Bold" HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="TextColor" Value="{StaticResource Primary}"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="False">
                                                    <Setter Property="TextColor" Value="White"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>

                                    <Border WidthRequest="5" HeightRequest="5" StrokeThickness="0"
                                            HorizontalOptions="Center" IsVisible="{Binding HasMeals}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="3"/>
                                        </Border.StrokeShape>
                                        <Border.BackgroundColor>#93C5FD</Border.BackgroundColor>
                                    </Border>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>

                <!-- ═══ HOUSEHOLD SIZE ═══ -->
                <Border Margin="16,14,16,0" StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                    </Border.Shadow>
                    <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto">
                        <!-- Icon placeholder -->
                        <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                Margin="0,0,12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Image Source="people.png" WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Household size" FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}"/>
                            <Label Text="{Binding HouseholdSizeText}" FontSize="11"
                                   TextColor="{StaticResource Gray400}"/>
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="2" Spacing="10" VerticalOptions="Center">
                            <Border WidthRequest="30" HeightRequest="30" StrokeThickness="0"
                                    BackgroundColor="{StaticResource AccentLight}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding DecrementHouseholdCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="−" FontSize="16" TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Text="{Binding HouseholdSize}" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}" VerticalOptions="Center"
                                   MinimumWidthRequest="22" HorizontalOptions="Center"/>
                            <Border WidthRequest="30" HeightRequest="30" StrokeThickness="0"
                                    BackgroundColor="{StaticResource AccentLight}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding IncrementHouseholdCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="+" FontSize="16" TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <!-- ═══ DAY LABEL ═══ -->
                <Label Text="{Binding SelectedDateLabel}"
                       Margin="16,16,16,8" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource Gray500}" CharacterSpacing="0.5"/>

                <!-- ═══ DAY ENTRIES ═══ -->
                <CollectionView ItemsSource="{Binding DayView}"
                                Margin="16,0,16,0" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DayEntryViewModel">
                            <Border StrokeThickness="0" BackgroundColor="White" Padding="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                                </Border.Shadow>

                                <VerticalStackLayout>

                                    <!-- TOP ROW: photo + name + arrow + remove -->
                                    <Grid Padding="14,12" ColumnDefinitions="Auto,*,Auto,Auto">

                                        <Border Grid.Column="0" WidthRequest="50" HeightRequest="50"
                                                StrokeThickness="0" Margin="0,0,12,0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="13"/>
                                            </Border.StrokeShape>
                                            <Image Source="{Binding Entry.Recipe.ImageUrl}" Aspect="AspectFill"/>
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding Entry.Recipe.Title}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource MidnightBlue}"/>
                                            <Label Text="{Binding Entry.Recipe.CookTimeMinutes, StringFormat='{0} min · {1}'}"
                                                   FontSize="11" TextColor="{StaticResource Gray400}"/>
                                        </VerticalStackLayout>

                                        <!-- View recipe -->
                                        <Border Grid.Column="2" WidthRequest="32" HeightRequest="32"
                                                StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                                VerticalOptions="Center" Margin="0,0,8,0">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=ViewRecipeCommand}"
                                                    CommandParameter="{Binding Entry.Recipe}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="›" FontSize="18" TextColor="{StaticResource Primary}"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Remove -->
                                        <Border Grid.Column="3" WidthRequest="32" HeightRequest="32"
                                                StrokeThickness="0" BackgroundColor="#FFF1F2"
                                                VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="16"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=RemoveEntryCommand}"
                                                    CommandParameter="{Binding Entry}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="✕" FontSize="12" TextColor="#E11D48"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                    </Grid>

                                    <BoxView HeightRequest="0.5" Color="{StaticResource Gray100}" Margin="14,0"/>

                                    <!-- PORTIONS ROW -->
                                    <Grid Padding="14,10" ColumnDefinitions="*,Auto"
                                          BackgroundColor="{StaticResource Gray100}">

                                        <!-- Left: status badge + portions text -->
                                        <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                            <Border StrokeThickness="0"
                                                    BackgroundColor="{Binding Entry.StatusBackground}"
                                                    Padding="10,4" HorizontalOptions="Start">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="10"/>
                                                </Border.StrokeShape>
                                                <Label Text="{Binding Entry.StatusText}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{Binding Entry.StatusColor}"/>
                                            </Border>
                                            <Label Text="{Binding Entry.PortionsText}"
                                                   FontSize="11" TextColor="{StaticResource Gray400}"/>
                                        </VerticalStackLayout>

                                        <!-- Right: − N + controls -->
                                        <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                            <Border WidthRequest="28" HeightRequest="28" StrokeThickness="0"
                                                    BackgroundColor="White">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=DecrementPortionsCommand}"
                                                        CommandParameter="{Binding Entry}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="−" FontSize="16" TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>

                                            <Label Text="{Binding Entry.TotalPortions}" FontSize="15"
                                                   FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"
                                                   VerticalOptions="Center" MinimumWidthRequest="22"
                                                   HorizontalOptions="Center"/>

                                            <Border WidthRequest="28" HeightRequest="28" StrokeThickness="0"
                                                    BackgroundColor="White">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=IncrementPortionsCommand}"
                                                        CommandParameter="{Binding Entry}"/>
                                                </Border.GestureRecognizers>
                                                <Label Text="+" FontSize="16" TextColor="{StaticResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <BoxView HeightRequest="0.5" Color="{StaticResource Gray200}" Margin="14,0"/>

                                    <!-- SKIP TODAY ROW (only show for today) -->
                                    <Grid Padding="14,10" ColumnDefinitions="*,Auto"
                                          IsVisible="{Binding IsToday}">
                                        <Label Grid.Column="0" Text="Eating this today?"
                                               FontSize="12" TextColor="{StaticResource Gray500}"
                                               VerticalOptions="Center"/>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                            <Border StrokeThickness="1" Padding="12,6">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="14"/>
                                                </Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=ToggleConsumedCommand}"
                                                        CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsConsumedToday}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#F0FDF4"/>
                                                        <Setter Property="Stroke" Value="#BBF7D0"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border"
                                                                 Binding="{Binding IsConsumedToday}" Value="False">
                                                        <Setter Property="BackgroundColor" Value="{StaticResource Gray100}"/>
                                                        <Setter Property="Stroke" Value="{StaticResource Gray200}"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding ConsumedLabel}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{Binding ConsumedTextColor}"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- ═══ ADD BUTTON ═══ -->
                <Border Margin="16,10,16,24" StrokeThickness="1.5"
                        Stroke="{StaticResource Tertiary}" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenModalCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Padding="14" Spacing="12">
                        <Border WidthRequest="36" HeightRequest="36" StrokeThickness="1.5"
                                Stroke="{StaticResource Tertiary}" BackgroundColor="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Label Text="+" FontSize="20" TextColor="{StaticResource Tertiary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" Margin="0,0,0,2"/>
                        </Border>
                        <Label Text="Plan a dish to cook..." FontSize="13"
                               TextColor="{StaticResource Tertiary}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ════════════ MODAL ════════════ -->
        <Grid IsVisible="{Binding IsModalVisible}">
            <BoxView Color="#66000000">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseModalCommand}"/>
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border VerticalOptions="End" StrokeThickness="0"
                    BackgroundColor="White" Padding="20,16,20,36">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0"/>
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Border WidthRequest="36" HeightRequest="4" StrokeThickness="0"
                            BackgroundColor="{StaticResource Gray200}" HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="2"/>
                        </Border.StrokeShape>
                    </Border>

                    <Label Text="Plan a dish" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource MidnightBlue}"/>

                    <!-- Search -->
                    <Border StrokeThickness="0" BackgroundColor="{StaticResource Gray100}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*" Padding="12,0">
                            <Image Grid.Column="0" Source="search.png" WidthRequest="16" HeightRequest="16"
                                   VerticalOptions="Center" Margin="0,0,8,0"/>
                            <Entry Grid.Column="1" Placeholder="Search recipes..."
                                   PlaceholderColor="{StaticResource Gray400}"
                                   TextColor="{StaticResource MidnightBlue}"
                                   BackgroundColor="Transparent" FontSize="14"
                                   HeightRequest="44" Text="{Binding SearchQuery}"/>
                        </Grid>
                    </Border>

                    <!-- Tabs -->
                    <HorizontalStackLayout Spacing="8">
                        <Border StrokeThickness="0" Padding="14,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TabAllCommand}"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TabAllActive}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TabAllActive}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Gray100}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="All" FontSize="12" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabAllActive}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabAllActive}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Gray500}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <Border StrokeThickness="0" Padding="14,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TabFavCommand}"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TabFavActive}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TabFavActive}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Gray100}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Favorites" FontSize="12" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabFavActive}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabFavActive}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Gray500}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>

                        <Border StrokeThickness="0" Padding="14,7">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TabMyCommand}"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding TabMyActive}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border" Binding="{Binding TabMyActive}" Value="False">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Gray100}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="My recipe" FontSize="12" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabMyActive}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding TabMyActive}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource Gray500}"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Recipe list in modal -->
                    <CollectionView ItemsSource="{Binding ModalRecipes}"
                                    HeightRequest="260" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="model:Recipe">
                                <Grid Padding="0,9" ColumnDefinitions="Auto,*,Auto">
                                    <BoxView Grid.ColumnSpan="3" HeightRequest="0.5"
                                             Color="{StaticResource Gray100}" VerticalOptions="End"/>
                                    <Border Grid.Column="0" WidthRequest="46" HeightRequest="46"
                                            StrokeThickness="0" Margin="0,0,12,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding Title}" FontSize="13" FontAttributes="Bold"
                                               TextColor="{StaticResource MidnightBlue}"/>
                                        <Label Text="{Binding CookTimeMinutes, StringFormat='{0} min · {1}'}"
                                               FontSize="11" TextColor="{StaticResource Gray400}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="2" WidthRequest="30" HeightRequest="30"
                                            StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                            VerticalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="15"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=AddRecipeCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="+" FontSize="20" TextColor="{StaticResource Primary}"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               Margin="0,0,0,2"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>