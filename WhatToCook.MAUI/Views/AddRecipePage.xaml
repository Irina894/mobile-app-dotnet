<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WhatToCook.MAUI.Views.AddRecipePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WhatToCook.MAUI.ViewModels"
    xmlns:model="clr-namespace:WhatToCook.MAUI.Models"
    x:DataType="vm:AddRecipeViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ═══ HEADER (без змін) ═══ -->
                <VerticalStackLayout
                    BackgroundColor="{StaticResource Primary}"
                    Padding="20,52,20,18"
                    Spacing="16">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                StrokeThickness="0" BackgroundColor="#33FFFFFF" HorizontalOptions="Start">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BackCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="←" TextColor="White" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="Add New Recipe" FontSize="20" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                        <Border Grid.Column="2" WidthRequest="70" HeightRequest="35"
                                StrokeThickness="0" BackgroundColor="White" HorizontalOptions="End">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="17"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Save" TextColor="{StaticResource Primary}"
                                   FontSize="14" FontAttributes="Bold"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- ═══ FORM ═══ -->
                <VerticalStackLayout Margin="16" Spacing="16">

                    <!-- Image Section (без змін) -->
                    <Border StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Padding="20" Spacing="12">
                            <Label Text="Recipe Photo" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}"/>
                            <Border StrokeThickness="1.5" Stroke="{StaticResource Gray200}"
                                    BackgroundColor="{StaticResource Gray100}" Padding="20">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16"/>
                                </Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PickImageCommand}"/>
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                                    <Border Grid.Row="0" WidthRequest="140" HeightRequest="140"
                                            StrokeThickness="1" Stroke="{StaticResource Gray300}"
                                            BackgroundColor="{StaticResource White}" HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ImagePreview}" Aspect="AspectFill"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               WidthRequest="140" HeightRequest="140">
                                            <Image.Triggers>
                                                <DataTrigger TargetType="Image" Binding="{Binding ImagePreview}" Value="{x:Null}">
                                                    <Setter Property="Source" Value="camera_placeholder.png"/>
                                                </DataTrigger>
                                            </Image.Triggers>
                                        </Image>
                                    </Border>
                                    <Label Grid.Row="1" Text="Tap to select photo from gallery"
                                           FontSize="12" TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center"/>
                                </Grid>
                            </Border>
                            <Label Text="Or enter image URL" FontSize="11"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                            <Entry Placeholder="https://example.com/photo.jpg"
                                   Text="{Binding ImageUrl}" FontSize="13" HeightRequest="40"
                                   BackgroundColor="{StaticResource Gray100}"
                                   TextColor="{StaticResource MidnightBlue}"
                                   PlaceholderColor="{StaticResource Gray400}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Basic Info Card (без змін) -->
                    <Border StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Padding="20" Spacing="16">
                            <Label Text="Basic Information" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}"/>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Recipe title *" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                <Entry Text="{Binding Title}" Placeholder="e.g., Chicken Parmesan"
                                       FontSize="14" HeightRequest="44"
                                       BackgroundColor="{StaticResource Gray100}"
                                       TextColor="{StaticResource MidnightBlue}"
                                       PlaceholderColor="{StaticResource Gray400}"/>
                            </VerticalStackLayout>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="6">
                                    <Label Text="Cook time (min)" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    <Entry Text="{Binding CookTimeMinutes}" Placeholder="30" Keyboard="Numeric"
                                           FontSize="14" HeightRequest="44"
                                           BackgroundColor="{StaticResource Gray100}"
                                           TextColor="{StaticResource MidnightBlue}"
                                           PlaceholderColor="{StaticResource Gray400}"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="6">
                                    <Label Text="Servings" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                    <Entry Text="{Binding Servings}" Placeholder="4" Keyboard="Numeric"
                                           FontSize="14" HeightRequest="44"
                                           BackgroundColor="{StaticResource Gray100}"
                                           TextColor="{StaticResource MidnightBlue}"
                                           PlaceholderColor="{StaticResource Gray400}"/>
                                </VerticalStackLayout>
                            </Grid>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Difficulty" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                <Border StrokeThickness="0" BackgroundColor="{StaticResource Gray100}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Picker Title="Select difficulty" ItemsSource="{Binding DifficultyOptions}"
                                            SelectedItem="{Binding Difficulty}"
                                            TextColor="{StaticResource MidnightBlue}"
                                            TitleColor="{StaticResource Gray400}"
                                            BackgroundColor="Transparent" HeightRequest="44"/>
                                </Border>
                            </VerticalStackLayout>
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Category" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                <Border StrokeThickness="0" BackgroundColor="{StaticResource Gray100}">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Picker Title="Select category" ItemsSource="{Binding CategoryOptions}"
                                            SelectedItem="{Binding Category}"
                                            TextColor="{StaticResource MidnightBlue}"
                                            TitleColor="{StaticResource Gray400}"
                                            BackgroundColor="Transparent" HeightRequest="44"/>
                                </Border>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Description Card (без змін) -->
                    <Border StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Padding="20" Spacing="12">
                            <Label Text="Description" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}"/>
                            <Editor Text="{Binding Description}"
                                    Placeholder="Write a short description of the recipe..."
                                    FontSize="14" HeightRequest="120"
                                    BackgroundColor="{StaticResource Gray100}"
                                    TextColor="{StaticResource MidnightBlue}"
                                    PlaceholderColor="{StaticResource Gray400}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ═══ INGREDIENTS CARD (НОВИЙ БЛОК) ═══ -->
                    <!-- Вставляємо між Description і My Recipe — стиль ідентичний іншим картками -->
                    <Border StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                        </Border.Shadow>

                        <VerticalStackLayout Padding="20" Spacing="12">

                            <!-- Заголовок + лічильник -->
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="Ingredients"
                                       FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource MidnightBlue}"
                                       VerticalOptions="Center"/>
                                <Border Grid.Column="1" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Primary}"
                                        Padding="10,4">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding SelectedCountText}"
                                           TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                </Border>
                            </Grid>

                            <Label Text="Tap to select ingredients for your recipe"
                                   FontSize="12" TextColor="{StaticResource Gray400}"/>

                            <!-- Сітка інгредієнтів 4 в рядку -->
                            <CollectionView
                                ItemsSource="{Binding AvailableIngredients}"
                                SelectionMode="None"
                                HeightRequest="230">
                                <CollectionView.ItemsLayout>
                                    <GridItemsLayout Orientation="Vertical"
                                                     Span="4"
                                                     HorizontalItemSpacing="8"
                                                     VerticalItemSpacing="10"/>
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="model:IngredientItem">
                                        <Border StrokeThickness="2"
                                                Stroke="{Binding SelectionBorderColor}"
                                                BackgroundColor="{Binding SelectionBackground}"
                                                Padding="6,8">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:AddRecipeViewModel}}, Path=ToggleIngredientCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="4">
                                                <Border WidthRequest="50" HeightRequest="50"
                                                        StrokeThickness="0" HorizontalOptions="Center">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="14"/>
                                                    </Border.StrokeShape>
                                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill"
                                                           WidthRequest="50" HeightRequest="50"/>
                                                </Border>
                                                <Label Text="{Binding Name}" FontSize="10"
                                                       TextColor="{StaticResource MidnightBlue}"
                                                       HorizontalOptions="Center"
                                                       HorizontalTextAlignment="Center"
                                                       MaxLines="1" LineBreakMode="TailTruncation"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                        </VerticalStackLayout>
                    </Border>

                    <!-- My Recipe Toggle (без змін) -->
                    <Border StrokeThickness="0" BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.1"/>
                        </Border.Shadow>
                        <Grid Padding="20" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="My Recipe" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource MidnightBlue}"/>
                                <Label Text="Mark as my personal recipe"
                                       FontSize="11" TextColor="{StaticResource Gray400}"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding IsMyRecipe}"
                                    VerticalOptions="Center" OnColor="{StaticResource Primary}"/>
                        </Grid>
                    </Border>

                    <!-- Save Button Bottom (без змін) -->
                    <Border Margin="0,8,0,24" StrokeThickness="0" BackgroundColor="{StaticResource Primary}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Save Recipe" FontSize="16" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"
                               VerticalOptions="Center" HeightRequest="50"/>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
