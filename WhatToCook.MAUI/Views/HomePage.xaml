<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WhatToCook.MAUI.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WhatToCook.MAUI.ViewModels"
    xmlns:model="clr-namespace:WhatToCook.MAUI.Models"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ HEADER ═══ -->
            <VerticalStackLayout
                Padding="20,52,20,16"
                Spacing="14"
                BackgroundColor="{StaticResource White}">

                <Label
                    Text="What to cook today?"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="{StaticResource MidnightBlue}"/>

                <!-- Search bar -->
                <Border
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Gray100}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="12,0">

                        <Image
                            Grid.Column="0"
                            Source="search.png"
                            WidthRequest="18"
                            HeightRequest="18"
                            VerticalOptions="Center"
                            Margin="0,0,8,0"/>

                        <Entry
                            Grid.Column="1"
                            Placeholder="Search recipes..."
                            PlaceholderColor="{StaticResource Gray400}"
                            TextColor="{StaticResource MidnightBlue}"
                            BackgroundColor="Transparent"
                            FontSize="14"
                            HeightRequest="44"
                            Text="{Binding SearchQuery}"
                            ReturnCommand="{Binding SearchCommand}"/>

                        <Image
                            Grid.Column="2"
                            Source="close.png"
                            WidthRequest="16"
                            HeightRequest="16"
                            VerticalOptions="Center"
                            Margin="8,0,0,0"
                            IsVisible="{Binding HasSearchQuery}">
                            <Image.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ClearSearchCommand}"/>
                            </Image.GestureRecognizers>
                        </Image>

                    </Grid>
                </Border>

                <!-- Search by ingredients header (з "Clear all" замість "See all") -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,2,0,0">
                    <Label
                        Grid.Column="0"
                        Text="Search by ingredients"
                        FontSize="13"
                        TextColor="{StaticResource Gray500}"
                        VerticalOptions="Center"/>
                    <Label
                        Grid.Column="1"
                        Text="Clear all"
                        FontSize="13"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasActiveFilters}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearFiltersCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- Ingredients horizontal scroll (тепер з підсвічуванням вибраних) -->
                <CollectionView
                    ItemsSource="{Binding Ingredients}"
                    HeightRequest="90"
                    HorizontalScrollBarVisibility="Never">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="16"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="model:IngredientItem">
                            <VerticalStackLayout Spacing="6" WidthRequest="64">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleIngredientCommand}"
                                        CommandParameter="{Binding .}"/>
                                </VerticalStackLayout.GestureRecognizers>

                                <Border
                                    WidthRequest="60"
                                    HeightRequest="60"
                                    StrokeThickness="0"
                                    Stroke="{Binding SelectionBorderColor}"
                                    HorizontalOptions="Center">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="30"/>
                                    </Border.StrokeShape>
                                    <Image
                                        Source="{Binding ImageUrl}"
                                        Aspect="AspectFill"
                                        WidthRequest="60"
                                        HeightRequest="60"/>
                                </Border>

                                <Label
                                    Text="{Binding Name}"
                                    FontSize="11"
                                    TextColor="{Binding ChipTextColor}"
                                    HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>

            <!-- ═══ FILTER BADGE (з'являється коли є вибрані інгредієнти) ═══ -->
            <Border
                IsVisible="{Binding ShowFilterBadge}"
                Margin="16,12,16,0"
                StrokeThickness="0"
                BackgroundColor="#EFF6FF"
                Padding="12,8">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>
                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Grid.Column="0"
                        Text="{Binding FilterBadgeText, StringFormat='🎯 {0}'}"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center"/>
                    <Label
                        Grid.Column="1"
                        Text="Clear"
                        FontSize="12"
                        FontAttributes="Bold"
                        TextColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearFiltersCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>
            </Border>

            <!-- ═══ SECTION TITLE (динамічний: "Popular recipes" / "Search results") ═══ -->
            <Label
                Text="{Binding RecipesSectionTitle}"
                Margin="20,20,20,12"
                FontSize="13"
                TextColor="{StaticResource Gray500}"/>

            <!-- ═══ LOADING INDICATOR ═══ -->
            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="{StaticResource Primary}"
                Margin="0,20,0,0"
                HorizontalOptions="Center"/>

            <!-- ═══ EMPTY STATE ═══ -->
            <VerticalStackLayout
                IsVisible="{Binding IsEmpty}"
                HorizontalOptions="Center"
                Spacing="12"
                Padding="40,20">
                <Label Text="🥗" FontSize="48" HorizontalOptions="Center"/>
                <Label
                    Text="No recipes found"
                    FontSize="18"
                    FontAttributes="Bold"
                    TextColor="{StaticResource MidnightBlue}"
                    HorizontalOptions="Center"/>
                <Label
                    Text="Try different ingredients or clear filters"
                    FontSize="13"
                    TextColor="{StaticResource Gray400}"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"/>
                <Border
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource Primary}"
                    Padding="20,12"
                    Margin="0,8,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ClearFiltersCommand}"/>
                    </Border.GestureRecognizers>
                    <Label
                        Text="Clear filters"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>
                </Border>
            </VerticalStackLayout>

            <!-- ═══ RECIPE LIST ═══ -->
            <CollectionView
                ItemsSource="{Binding Recipes}"
                IsVisible="{Binding IsNotEmpty}"
                Margin="16,0,16,24"
                SelectionMode="None">

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="14"/>
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Recipe">

                        <Border StrokeThickness="0" Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="24"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow
                                    Brush="#22000000"
                                    Offset="0,6"
                                    Radius="20"
                                    Opacity="0.18"/>
                            </Border.Shadow>

                            <Grid RowDefinitions="200,Auto">

                                <!-- PHOTO -->
                                <Grid Grid.Row="0">
                                    <Image
                                        Source="{Binding ImageUrl}"
                                        Aspect="AspectFill"
                                        HeightRequest="200"/>

                                    <!-- Rating badge -->
                                    <Border
                                        HorizontalOptions="End"
                                        VerticalOptions="Start"
                                        Margin="0,12,12,0"
                                        StrokeThickness="0.5"
                                        Stroke="#55FFFFFF"
                                        BackgroundColor="#44FFFFFF"
                                        Padding="8,4">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12"/>
                                        </Border.StrokeShape>
                                        <Label
                                            Text="{Binding RatingText}"
                                            TextColor="White"
                                            FontSize="11"
                                            FontAttributes="Bold"/>
                                    </Border>

                                    <!-- Favorite button -->
                                    <Border
                                        HorizontalOptions="Start"
                                        VerticalOptions="Start"
                                        Margin="12,12,0,0"
                                        WidthRequest="36"
                                        HeightRequest="36"
                                        StrokeThickness="0"
                                        BackgroundColor="#44000000">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18"/>
                                        </Border.StrokeShape>
                                        <Image
                                            Source="{Binding FavoriteIcon}"
                                            Aspect="AspectFit"
                                            Margin="10"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center">
                                            <Image.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ToggleFavoriteCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Image.GestureRecognizers>
                                        </Image>
                                    </Border>
                                </Grid>

                                <!-- FROSTED BODY -->
                                <VerticalStackLayout
                                    Grid.Row="1"
                                    Spacing="10"
                                    Padding="16,14,16,16"
                                    BackgroundColor="{Binding AccentColor}">

                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label
                                            Grid.Column="0"
                                            Text="{Binding Title}"
                                            TextColor="White"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            VerticalOptions="Center"/>
                                        <Border
                                            Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="#33000000"
                                            Padding="10,5"
                                            VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14"/>
                                            </Border.StrokeShape>
                                            <Label
                                                Text="{Binding CookTimeMinutes, StringFormat='⏱ {0} min'}"
                                                TextColor="White"
                                                FontSize="11"/>
                                        </Border>
                                    </Grid>

                                    <Label
                                        Text="{Binding ShortDescription}"
                                        TextColor="#CCFFFFFF"
                                        FontSize="13"
                                        LineHeight="1.5"
                                        MaxLines="2"
                                        LineBreakMode="TailTruncation"/>

                                    <HorizontalStackLayout Spacing="8">
                                        <Border
                                            StrokeThickness="1"
                                            Stroke="#55FFFFFF"
                                            BackgroundColor="Transparent"
                                            Padding="10,5">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Category}" TextColor="White" FontSize="11"/>
                                        </Border>
                                        <Border
                                            StrokeThickness="1"
                                            Stroke="#55FFFFFF"
                                            BackgroundColor="Transparent"
                                            Padding="10,5">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding DifficultyLabel}" TextColor="White" FontSize="11"/>
                                        </Border>
                                        <Border
                                            StrokeThickness="1"
                                            Stroke="#55FFFFFF"
                                            BackgroundColor="Transparent"
                                            Padding="10,5">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding ServingsLabel}" TextColor="White" FontSize="11"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Border
                                        StrokeThickness="0"
                                        BackgroundColor="White"
                                        Padding="0,13">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=ViewRecipeCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                        <Label
                                            Text="View recipe"
                                            HorizontalOptions="Center"
                                            FontSize="15"
                                            FontAttributes="Bold"
                                            TextColor="{Binding AccentTextColor}"/>
                                    </Border>

                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
