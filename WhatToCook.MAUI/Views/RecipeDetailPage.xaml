<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WhatToCook.MAUI.Views.RecipeDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WhatToCook.MAUI.ViewModels"
    x:DataType="vm:RecipeDetailViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <Grid>

        <!-- ══ LOADING ══ -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
            <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}"
                               WidthRequest="40" HeightRequest="40"/>
            <Label Text="Loading recipe..." FontSize="14"
                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- ══ ERROR ══ -->
        <VerticalStackLayout IsVisible="{Binding HasError}"
                             VerticalOptions="Center" HorizontalOptions="Center"
                             Spacing="16" Padding="40">
            <Label Text="😕" FontSize="48" HorizontalOptions="Center"/>
            <Label Text="Could not load recipe" FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource MidnightBlue}" HorizontalOptions="Center"/>
            <Border StrokeThickness="0" BackgroundColor="{StaticResource Primary}" Padding="20,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding RetryCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="Try again" TextColor="White" FontSize="14"
                       FontAttributes="Bold" HorizontalOptions="Center"/>
            </Border>
        </VerticalStackLayout>

        <!-- ══ MAIN CONTENT ══ -->
        <ScrollView IsVisible="{Binding IsLoading,
                        Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <!-- ═══ HERO PHOTO ═══ -->
                <Grid HeightRequest="300">
                    <Image Source="{Binding Recipe.ImageUrl}" Aspect="AspectFill" HeightRequest="300"/>

                    <!-- Градієнт знизу -->
                    <BoxView VerticalOptions="End" HeightRequest="160" Opacity="0.65">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#CC000000" Offset="1"/>
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Кнопка назад -->
                    <Border HorizontalOptions="Start" VerticalOptions="Start"
                            Margin="16,52,0,0" WidthRequest="40" HeightRequest="40"
                            StrokeThickness="0" BackgroundColor="#44000000">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="←" TextColor="White" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Кнопка фаворит -->
                    <Border HorizontalOptions="End" VerticalOptions="Start"
                            Margin="0,52,16,0" WidthRequest="40" HeightRequest="40"
                            StrokeThickness="0" BackgroundColor="#44000000">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFavoriteCommand}"/>
                        </Border.GestureRecognizers>
                        <Image Source="{Binding Recipe.FavoriteIcon}" Aspect="AspectFit"
                               Margin="10" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <!-- Назва + категорія поверх фото -->
                    <VerticalStackLayout VerticalOptions="End" Padding="20,0,20,20" Spacing="6">
                        <Label Text="{Binding Recipe.Title}" FontSize="26" FontAttributes="Bold"
                               TextColor="White" LineBreakMode="TailTruncation" MaxLines="2"/>
                        <HorizontalStackLayout Spacing="8">
                            <Border StrokeThickness="0" BackgroundColor="#44FFFFFF" Padding="10,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Recipe.RatingText}" TextColor="White"
                                       FontSize="12" FontAttributes="Bold"/>
                            </Border>
                            <Border StrokeThickness="0" BackgroundColor="#44FFFFFF" Padding="10,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Label Text="{Binding Recipe.Category}" TextColor="White" FontSize="12"/>
                            </Border>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ═══ STATS ROW ═══ -->
                <Grid Margin="16,16,16,0" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="White" Padding="12,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="⏱" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Recipe.CookTimeMinutes, StringFormat='{0} min'}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}" HorizontalOptions="Center"/>
                            <Label Text="Cook time" FontSize="10"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeThickness="0" BackgroundColor="White" Padding="12,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="🍽" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Recipe.Servings}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}" HorizontalOptions="Center"/>
                            <Label Text="Servings" FontSize="10"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" StrokeThickness="0" BackgroundColor="White" Padding="12,14">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="📊" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="{Binding Recipe.Difficulty}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource MidnightBlue}" HorizontalOptions="Center"/>
                            <Label Text="Difficulty" FontSize="10"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ═══ ОПИС ═══ -->
                <Border Margin="16,16,16,0" StrokeThickness="0" BackgroundColor="White" Padding="20">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="About this recipe" FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource MidnightBlue}"/>
                        <Label Text="{Binding Recipe.Description}" FontSize="14"
                               TextColor="{StaticResource Gray500}" LineHeight="1.6"/>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ ІНГРЕДІЄНТИ РЕЦЕПТУ ═══ -->
                <VerticalStackLayout Margin="16,20,16,0" Spacing="12">

                    <Label Text="Ingredients" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource MidnightBlue}"/>

                    <!-- Якщо є інгредієнти — показуємо сітку -->
                    <CollectionView ItemsSource="{Binding RecipeIngredients}"
                                    IsVisible="{Binding HasIngredients}"
                                    SelectionMode="None"
                                    HeightRequest="120">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecipeIngredientDetail">
                                <VerticalStackLayout Spacing="6" WidthRequest="72">
                                    <Border WidthRequest="64" HeightRequest="64"
                                            StrokeThickness="0" HorizontalOptions="Center">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18"/>
                                        </Border.StrokeShape>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#F0F4FF" Offset="0"/>
                                                <GradientStop Color="#E8F0FE" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill"
                                               WidthRequest="64" HeightRequest="64"/>
                                    </Border>
                                    <Label Text="{Binding IngredientName}" FontSize="11"
                                           TextColor="{StaticResource Gray600}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           MaxLines="2" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Якщо інгредієнтів немає -->
                    <Border IsVisible="{Binding HasIngredients,
                                Converter={StaticResource InverseBoolConverter}}"
                            StrokeThickness="1" Stroke="{StaticResource Gray200}"
                            BackgroundColor="{StaticResource Gray100}" Padding="16,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Label Text="No ingredients specified for this recipe."
                               FontSize="13" TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center"/>
                    </Border>

                </VerticalStackLayout>

                <!-- ═══ ПОКРОКОВА ІНСТРУКЦІЯ ═══ -->
                <VerticalStackLayout Margin="16,20,16,32" Spacing="12">
                    <Label Text="How to cook" FontSize="17" FontAttributes="Bold"
                           TextColor="{StaticResource MidnightBlue}"/>

                    <CollectionView ItemsSource="{Binding Steps}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:RecipeStep">
                                <Border Margin="0,0,0,10" StrokeThickness="0"
                                        BackgroundColor="White" Padding="16">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="16"/>
                                    </Border.StrokeShape>
                                    <Border.Shadow>
                                        <Shadow Brush="#11000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                        <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                                StrokeThickness="0" BackgroundColor="{StaticResource Primary}"
                                                VerticalOptions="Start">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding NumberLabel}" TextColor="White"
                                                   FontSize="14" FontAttributes="Bold"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Grid.Column="1" Text="{Binding Description}"
                                               FontSize="14" TextColor="{StaticResource Gray600}"
                                               LineHeight="1.5" VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
