<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WhatToCook.MAUI.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:WhatToCook.MAUI.ViewModels"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ═══ BLUE HEADER ═══ -->
            <Grid
                Padding="20,52,20,28"
                BackgroundColor="{StaticResource Primary}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Edit button top-right -->
                <Border
                    Grid.Row="0"
                    HorizontalOptions="End"
                    StrokeThickness="1"
                    Stroke="#55FFFFFF"
                    BackgroundColor="#33FFFFFF"
                    Padding="12,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditProfileCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="✏️  Edit" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                </Border>

                <!-- Avatar -->
                <Grid
                    Grid.Row="1"
                    HorizontalOptions="Center"
                    WidthRequest="88"
                    HeightRequest="88"
                    Margin="0,8,0,0">

                    <Border
                        WidthRequest="84"
                        HeightRequest="84"
                        StrokeThickness="3"
                        Stroke="#77FFFFFF"
                        HorizontalOptions="Center"
                        VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="42"/>
                        </Border.StrokeShape>
                        <!-- If photo exists show Image, else show initials -->
                        <Grid>
                            <Label
                                Text="{Binding UserInitials}"
                                TextColor="{StaticResource Primary}"
                                FontSize="30"
                                FontAttributes="Bold"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                BackgroundColor="White"/>
                        </Grid>
                    </Border>

                    <!-- Camera badge -->
                    <Border
                        WidthRequest="28"
                        HeightRequest="28"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        HorizontalOptions="End"
                        VerticalOptions="End">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#33000000" Offset="0,2" Radius="6" Opacity="0.3"/>
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ChangePhotoCommand}"/>
                        </Border.GestureRecognizers>
                        <Image Source="camera.png" WidthRequest="14" HeightRequest="14"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Name -->
                <Label
                    Grid.Row="2"
                    Text="{Binding FullName}"
                    TextColor="White"
                    FontSize="20"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    Margin="0,10,0,4"/>

                <!-- Email -->
                <Label
                    Grid.Row="3"
                    Text="{Binding Email}"
                    TextColor="#BBFFFFFF"
                    FontSize="13"
                    HorizontalOptions="Center"/>
            </Grid>

            <VerticalStackLayout Padding="16" Spacing="12">

                <!-- ═══ PERSONAL INFO ═══ -->
                <Border StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout>

                        <Grid Padding="16,14,16,10" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Personal info"
                                   FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            <Label Grid.Column="1" Text="Edit"
                                   FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditProfileCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Name row -->
                        <Grid Padding="16,10" ColumnDefinitions="Auto,*"
                              BackgroundColor="{StaticResource Gray100}">
                            <Border Grid.Column="0"
                                    WidthRequest="34" HeightRequest="34"
                                    StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                    VerticalOptions="Center" Margin="0,0,12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Image Source="profile.png" WidthRequest="16" HeightRequest="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Full name" FontSize="11" TextColor="{StaticResource Gray400}"/>
                                <Label Text="{Binding FullName}" FontSize="13"
                                       FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Email row -->
                        <Grid Padding="16,10" ColumnDefinitions="Auto,*">
                            <Border Grid.Column="0"
                                    WidthRequest="34" HeightRequest="34"
                                    StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                    VerticalOptions="Center" Margin="0,0,12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Image Source="email.png" WidthRequest="16" HeightRequest="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Email" FontSize="11" TextColor="{StaticResource Gray400}"/>
                                <Label Text="{Binding Email}" FontSize="13"
                                       FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Phone row -->
                        <Grid Padding="16,10,16,14" ColumnDefinitions="Auto,*"
                              BackgroundColor="{StaticResource Gray100}">
                            <Border Grid.Column="0"
                                    WidthRequest="34" HeightRequest="34"
                                    StrokeThickness="0" BackgroundColor="{StaticResource AccentLight}"
                                    VerticalOptions="Center" Margin="0,0,12,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10"/>
                                </Border.StrokeShape>
                                <Image Source="phone.png" WidthRequest="16" HeightRequest="16"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Phone" FontSize="11" TextColor="{StaticResource Gray400}"/>
                                <Label Text="{Binding Phone}" FontSize="13"
                                       FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ═══ DIET & LIFESTYLE ═══ -->
                <Border StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="0,0,0,14">

                        <Grid Padding="16,14,16,10" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Diet &amp; lifestyle"
                                   FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            <Label Grid.Column="1" Text="Edit"
                                   FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditDietCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <FlexLayout
                            Padding="16,4,16,0"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Start">

                            <!-- Vegetarian -->
                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#BBF7D0" BackgroundColor="#F0FDF4" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🥗  Vegetarian" FontSize="12" TextColor="#16A34A"/>
                            </Border>

                            <!-- Gluten-free -->
                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#DDD6FE" BackgroundColor="#F5F3FF" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🌾  Gluten-free" FontSize="12" TextColor="#7C3AED"/>
                            </Border>

                            <!-- Low-carb -->
                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#FED7AA" BackgroundColor="#FFF7ED" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🔥  Low-carb" FontSize="12" TextColor="#C2410C"/>
                            </Border>

                            <!-- Dairy-free -->
                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#BFDBFE" BackgroundColor="#EFF6FF" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🥛  Dairy-free" FontSize="12" TextColor="#2563EB"/>
                            </Border>

                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ ALLERGIES ═══ -->
                <Border StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout Padding="0,0,0,14">

                        <Grid Padding="16,14,16,10" ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Allergies"
                                   FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MidnightBlue}"/>
                            <Label Grid.Column="1" Text="Edit"
                                   FontSize="12" TextColor="{StaticResource Primary}" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditAllergiesCommand}"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <FlexLayout
                            Padding="16,4,16,0"
                            Wrap="Wrap"
                            Direction="Row"
                            JustifyContent="Start"
                            AlignItems="Start">

                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#FECDD3" BackgroundColor="#FFF1F2" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🥜  Peanuts" FontSize="12" TextColor="#E11D48"/>
                            </Border>

                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#FECDD3" BackgroundColor="#FFF1F2" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🥛  Lactose" FontSize="12" TextColor="#E11D48"/>
                            </Border>

                            <Border Margin="0,0,8,8" StrokeThickness="1"
                                    Stroke="#FECDD3" BackgroundColor="#FFF1F2" Padding="10,5">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <Label Text="🦐  Shellfish" FontSize="12" TextColor="#E11D48"/>
                            </Border>

                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ SIGN OUT ═══ -->
                <Border StrokeThickness="0" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#11000000" Offset="0,2" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SignOutCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid Padding="16,14" ColumnDefinitions="Auto,*">
                        <Border Grid.Column="0"
                                WidthRequest="34" HeightRequest="34"
                                StrokeThickness="0" BackgroundColor="#FFF1F2"
                                VerticalOptions="Center" Margin="0,0,12,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Image Source="logout.png" WidthRequest="16" HeightRequest="16"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="Sign out"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="#E11D48" VerticalOptions="Center"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>